{
  "multipart": [
    {
      "apply": {
        "model": "apocalypsenow:block/ropeextension_post"
      }
    },
    {
      "when": {
        "north": true
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_side"
      }
    },
    {
      "when": {
        "east": true
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_side",
        "y": 90
      }
    },
    {
      "when": {
        "south": true
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_side_alt"
      }
    },
    {
      "when": {
        "west": true
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_side_alt",
        "y": 90
      }
    },
    {
      "when": {
        "north": false
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_noside"
      }
    },
    {
      "when": {
        "east": false
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_noside_alt"
      }
    },
    {
      "when": {
        "south": false
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_noside_alt",
        "y": 90
      }
    },
    {
      "when": {
        "west": false
      },
      "apply": {
        "model": "apocalypsenow:block/ropeextension_noside",
        "y": 270
      }
    }
  ]
}